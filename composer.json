{
  "name": "monkeyscloud/monkeyslegion-files",
  "description": "Production-ready file storage and upload management for the MonkeysLegion framework ecosystem",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "monkeyslegion",
    "files",
    "storage",
    "upload",
    "s3",
    "gcs",
    "image-processing",
    "chunked-upload"
  ],
  "authors": [
    {
      "name": "MonkeysCloud",
      "email": "dev@monkeyscloud.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "monkeyscloud/monkeyslegion-mlc": "^3.1",
    "monkeyscloud/monkeyslegion-cache": "^1.0",
    "monkeyscloud/monkeyslegion-database": "^1.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "ext-gd": "*",
    "aws/aws-sdk-php": "^3.300",
    "friendsofphp/php-cs-fixer": "^3.0",
    "google/cloud-storage": "^1.35",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^11.0"
  },
  "suggest": {
    "aws/aws-sdk-php": "Required for S3-compatible storage (^3.300)",
    "google/cloud-storage": "Required for Google Cloud Storage (^1.35)",
    "ext-gd": "Required for image processing with GD",
    "ext-imagick": "Required for advanced image processing with ImageMagick"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Files\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Files\\Tests\\": "tests/"
    }
  },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src --memory-limit=2G",
        "quality": [
            "@phpstan",
            "@test"
        ],
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "branch-alias": {
      "dev-main": "2.0.x-dev"
    }
  }
}
