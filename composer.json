{
  "name": "monkeyscloud/monkeyslegion-files",
  "description": "Production-ready file storage, upload, and image processing for the MonkeysLegion framework",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "monkeyslegion",
    "files",
    "storage",
    "upload",
    "s3",
    "gcs",
    "azure",
    "image-processing",
    "chunked-upload"
  ],
  "authors": [
    {
      "name": "MonkeysCloud",
      "email": "dev@monkeyscloud.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "monkeyscloud/monkeyslegion-mlc": "^3.1.2",
    "monkeyscloud/monkeyslegion-cache": "^2.0",
    "monkeyscloud/monkeyslegion-database": "^2.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "ext-gd": "*",
    "aws/aws-sdk-php": "^3.300",
    "google/cloud-storage": "^1.35",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.0"
  },
  "suggest": {
    "aws/aws-sdk-php": "Required for S3-compatible storage (^3.300)",
    "google/cloud-storage": "Required for Google Cloud Storage (^1.35)",
    "microsoft/azure-storage-blob": "Required for Azure Blob Storage (^1.5)",
    "ext-gd": "Required for image processing with GD",
    "ext-imagick": "Required for advanced image processing with ImageMagick"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Files\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Files\\Tests\\": "tests/"
    },
    "files": [
      "stubs/Imagick.php"
    ]
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "phpstan": "phpstan analyse src --memory-limit=2G",
    "quality": [
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "branch-alias": {
      "dev-main": "2.1.x-dev"
    }
  }
}
